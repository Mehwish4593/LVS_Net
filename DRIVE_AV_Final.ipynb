    "import tensorflow as tf\n",
    "from tensorflow.keras import backend as K\n",
    "\n",
    "# Dice Coefficient for multiple classes\n",
    "def dice_coef_multiclass(y_true, y_pred, num_classes):\n",
    "    dice = 0\n",
    "    y_true = tf.cast(y_true, tf.int32)  # Ensure labels are integers\n",
    "    y_true = tf.one_hot(y_true, depth=num_classes)  # Apply one-hot encoding\n",
    "\n",
    "    for class_id in range(num_classes):\n",
    "        y_true_f = tf.reshape(y_true[..., class_id], [-1])\n",
    "        y_pred_f = tf.reshape(y_pred[..., class_id], [-1])\n",
    "        intersection = tf.reduce_sum(y_true_f * y_pred_f)\n",
    "        dice += (2. * intersection + K.epsilon()) / (\n",
    "            tf.reduce_sum(y_true_f) + tf.reduce_sum(y_pred_f) + K.epsilon())\n",
    "\n",
    "    return dice / num_classes\n",
    "\n",
    "def dice_coef_multiclass_wrapper(num_classes):\n",
    "    def dice_coef(y_true, y_pred):\n",
    "        return dice_coef_multiclass(y_true, y_pred, num_classes=num_classes)\n",
    "    return dice_coef\n",
    "def dice_loss_multiclass(y_true, y_pred, num_classes):\n",
    "    return 1 - dice_coef_multiclass(y_true, y_pred, num_classes)\n",
    "\n",
    "def dice_loss_multiclass_wrapper(num_classes):\n",
    "    def dice_loss(y_true, y_pred):\n",
    "        return 1 - dice_coef_multiclass(y_true, y_pred, num_classes)\n",
    "    return dice_loss\n",
    "\n",
    "\n",
    "def iou_per_class(y_true, y_pred, smooth=1e-6):\n",
    "    intersection = tf.reduce_sum(y_true * y_pred, axis=[1, 2])\n",
    "    union = tf.reduce_sum(y_true + y_pred, axis=[1, 2]) - intersection\n",
    "    iou = (intersection + smooth) / (union + smooth)\n",
    "    return iou\n",
    "\n",
    "def mean_iou(y_true, y_pred, num_classes, smooth=1e-6):\n",
    "    y_true_int = tf.cast(y_true, tf.int32)  # Convert y_true to int32\n",
    "    y_true_one_hot = tf.one_hot(y_true_int, depth=num_classes, axis=-1)\n",
    "\n",
    "    iou = iou_per_class(y_true_one_hot, y_pred, smooth)\n",
    "    return tf.reduce_mean(iou)\n",
    "\n",
    "# Wrapper function to include num_classes\n",
    "def mean_iou_wrapper(num_classes):\n",
    "    def mean_iou_fixed(y_true, y_pred):\n",
    "        return mean_iou(y_true, y_pred, num_classes)\n",
    "    mean_iou_fixed.__name__ = f'mean_iou_{num_classes}'\n",
    "    return mean_iou_fixed\n",
    "\n",
    "\n",
    "def iou_loss(y_true, y_pred, num_classes, smooth=1e-6):\n",
    "    y_pred = tf.nn.softmax(y_pred)  # Apply softmax to logits to convert to probability\n",
    "    y_true_int = tf.cast(y_true, tf.int32)  # Convert y_true to int32 if not already\n",
    "    y_true_one_hot = tf.one_hot(y_true_int, depth=num_classes, axis=-1)  # One-hot encode y_true\n",
    "\n",
    "    iou = iou_per_class(y_true_one_hot, y_pred, smooth)\n",
    "    # For a loss, we subtract IOU from 1\n",
    "    loss = 1 - iou\n",
    "    # Return the mean loss over all classes\n",
    "    return tf.reduce_mean(loss)\n",
    "\n",
    "# Wrapper function to include num_classes as a fixed parameter\n",
    "def iou_loss_wrapper(num_classes):\n",
    "    def iou_loss_fixed(y_true, y_pred):\n",
    "        return iou_loss(y_true, y_pred, num_classes)\n",
    "    iou_loss_fixed.__name__ = f'iou_loss_{num_classes}'\n",
    "    return iou_loss_fixed\n",
    "\n",
    "def sensitivity_per_class(y_true, y_pred):\n",
    "    # Assuming y_true is a batch of integer labels, one-hot encode it to match y_pred's shape\n",
    "    num_classes = tf.shape(y_pred)[-1]\n",
    "    y_true_one_hot = tf.one_hot(tf.cast(tf.squeeze(y_true), tf.int32), depth=num_classes)\n",
    "\n",
    "    # Flatten the tensors to 2D: shape is now (batch_size * height * width, num_classes)\n",
    "    y_true_reshaped = tf.reshape(y_true_one_hot, (-1, num_classes))\n",
    "    y_pred_reshaped = tf.reshape(y_pred, (-1, num_classes))\n",
    "\n",
    "    sensitivities = []\n",
    "    for class_id in range(num_classes):\n",
    "        # Convert class_id to a tensor of the appropriate type\n",
    "        class_id_tensor = tf.cast(class_id, dtype=tf.int64)\n",
    "\n",
    "        # Select the predictions for the current class\n",
    "        y_true_class = tf.equal(tf.argmax(y_true_reshaped, axis=-1), class_id_tensor)\n",
    "        y_pred_class = tf.equal(tf.argmax(y_pred_reshaped, axis=-1), class_id_tensor)\n",
    "\n",
    "        # Calculate true positives and possible positives for the current class\n",
    "        true_positives = tf.reduce_sum(tf.cast(y_true_class, tf.float32) * tf.cast(y_pred_class, tf.float32))\n",
    "        possible_positives = tf.reduce_sum(tf.cast(y_true_class, tf.float32))\n",
    "\n",
    "        # Calculate sensitivity for the current class\n",
    "        sensitivity = true_positives / (possible_positives + tf.keras.backend.epsilon())\n",
    "        sensitivities.append(sensitivity)\n",
    "        #print(str(class_id), str(sensitivity))\n",
    "    # Return the mean sensitivity across all classes\n",
    "    return tf.reduce_mean(tf.stack(sensitivities), axis=0)\n",
    "\n",
    "def specificity_per_class(y_true, y_pred):\n",
    "    # Step 1: Validate the structure of `y_true` (add this if you're unsure about its shape)\n",
    "    #print(\"Original y_true shape:\", y_true.shape)  # Debugging statement\n",
    "\n",
    "    # Assuming y_true needs one-hot encoding to match y_pred's structure\n",
    "    num_classes = tf.shape(y_pred)[-1]  # Ensure this matches your model's output\n",
    "\n",
    "    # One-hot encode y_true\n",
    "    y_true_one_hot = tf.one_hot(tf.cast(tf.squeeze(y_true), tf.int32), depth=num_classes)\n",
    "\n",
    "    # Step 2: Verify one-hot encoding result\n",
    "    #print(\"y_true_one_hot shape:\", y_true_one_hot.shape)  # Debugging statement\n",
    "\n",
    "    # Reshape one-hot encoded y_true to match y_pred's flat structure\n",
    "    y_true_reshaped = tf.reshape(y_true_one_hot, (-1, num_classes))\n",
    "    y_pred_reshaped = tf.reshape(y_pred, (-1, num_classes))\n",
    "\n",
    "    # Ensure that the number of elements in each reshaped tensor is the same\n",
    "    # (This line might not be needed if you're sure about the shapes)\n",
    "    # y_true_reshaped = tf.ensure_shape(y_true_reshaped, [None, num_classes])\n",
    "\n",
    "    specificities = []\n",
    "    for class_id in range(num_classes):\n",
    "        # Convert class_id to the appropriate type\n",
    "        class_id_tensor = tf.cast(class_id, dtype=tf.int64)\n",
    "\n",
    "        # Calculate specificity components\n",
    "        y_true_class_neg = 1 - tf.cast(tf.equal(tf.argmax(y_true_reshaped, axis=-1), class_id_tensor), tf.float32)\n",
    "        y_pred_class_neg = 1 - tf.cast(tf.equal(tf.argmax(y_pred_reshaped, axis=-1), class_id_tensor), tf.float32)\n",
    "\n",
    "        true_negatives = tf.reduce_sum(y_true_class_neg * y_pred_class_neg)\n",
    "        possible_negatives = tf.reduce_sum(y_true_class_neg)\n",
    "\n",
    "        specificity = true_negatives / (possible_negatives + tf.keras.backend.epsilon())\n",
    "        specificities.append(specificity)\n",
    "        #print(str(class_id), str(specificity))\n",
    "\n",
    "    return tf.reduce_mean(tf.stack(specificities), axis=0)\n",
    "\n",
    "\n",
    "# Example usage with a Keras model\n",
    "num_classes = 3  # Specify the correct number of classes for your dataset\n",
    "# model.compile(optimizer='adam',\n",
    "#               loss='categorical_crossentropy',\n",
    "#               metrics=[mean_iou_wrapper(num_classes)])\n",
    "\n",
    "\n",
    "model.compile(\n",
    "    optimizer=tf.keras.optimizers.Adam(0.001),\n",
    "    loss=dice_loss_multiclass_wrapper(num_classes),  # Use the wrapper here\n",
    "    metrics=[dice_coef_multiclass_wrapper(num_classes), mean_iou_wrapper(num_classes), sensitivity_per_class, specificity_per_class],\n",
    "    run_eagerly=True\n",
    ")\n",
    "\n",
