    "from PIL import Image\n",
    "import numpy as np\n",
    "import os\n",
    "\n",
    "def get_data(path, num_classes):\n",
    "    images_path = os.path.join(path, 'images')\n",
    "    masks_path = os.path.join(path, 'GT_AV2')\n",
    "\n",
    "    images_ids = [f for f in sorted(os.listdir(images_path)) if not os.path.isdir(os.path.join(images_path, f))]\n",
    "    mask1_ids = [f for f in sorted(os.listdir(masks_path)) if not os.path.isdir(os.path.join(masks_path, f))]\n",
    "\n",
    "    X = np.zeros((len(images_ids), 512, 512, 3), dtype=np.float32)  # Ensure dimensions are correct\n",
    "    y = np.zeros((len(mask1_ids), 512, 512), dtype=np.float32)\n",
    "    y1 = np.zeros((len(mask1_ids), 512, 512), dtype=np.float32)\n",
    "\n",
    "    print('Getting and resizing images ... ')\n",
    "    for n, id_ in enumerate(images_ids):\n",
    "        try:\n",
    "            img_file = os.path.join(images_path, id_)\n",
    "            img = Image.open(img_file)  # Load the image with Pillow\n",
    "            img = img.resize((512, 512), Image.NEAREST)  # Resize with nearest neighbor\n",
    "            img = img.convert('RGB')  # Ensure the image is in RGB format\n",
    "            img = np.array(img, dtype=np.float32) / 255.0  # Convert to numpy array and normalize\n",
    "            X[n] = img\n",
    "        except Exception as e:\n",
    "            print(f\"Skipping file {id_}, as it's not recognized as an image or another error occurred: {e}\")\n",
    "            continue\n",
    "\n",
    "    print('Getting and resizing masks ... ')\n",
    "    for n, id_ in enumerate(mask1_ids):\n",
    "        try:\n",
    "            mask_file = os.path.join(masks_path, id_)\n",
    "            mask = Image.open(mask_file).convert('L')  # Load mask in grayscale\n",
    "            mask = mask.resize((512, 512), Image.NEAREST)  # Resize with nearest neighbor\n",
    "            mask = np.array(mask, dtype=np.float32)  # Convert to numpy array\n",
    "\n",
    "            conditions = [\n",
    "                (mask == 0),    # Condition for class 0\n",
    "                (mask == 128),  # Condition for class 1\n",
    "                (mask == 255)   # Condition for class 2\n",
    "            ]\n",
    "            choices = [0, 1, 2]  # The class labels\n",
    "            mask_classified = np.select(conditions, choices, default=-1)\n",
    "\n",
    "            y1[n] = mask_classified\n",
    "            y[n] = mask_classified.squeeze()  # Remove the extra dimension after one-hot encoding\n",
    "        except Exception as e:\n",
    "            print(f\"Error processing mask file {id_}: {e}\")\n",
    "            continue\n",
    "\n",
    "    print('Done!')\n",
    "    return X, y1, y\n"
   ]
