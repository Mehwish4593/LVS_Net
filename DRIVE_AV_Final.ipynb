    "# from skimage.measure import block_reduce\n",
    "import numpy as geek\n",
    "def sem_attention_block(inputs):\n",
    "    shape=inputs.shape\n",
    "    F2=Conv2D(shape[3],1, padding='same') (inputs)\n",
    "    F2=BatchNormalization() (F2)\n",
    "    F2=Activation('relu') (F2)\n",
    "    x1=MaxPooling2D(pool_size=(shape[1],shape[2]),padding='same')(F2)\n",
    "    x2=AveragePooling2D(pool_size=(shape[1],shape[2]),padding='same')(F2)\n",
    "    con1 = Concatenate()([x1,x2])\n",
    "    F3=Conv2D(shape[3],1, padding='same') (con1)\n",
    "    F3=BatchNormalization() (F3)\n",
    "    F33=Activation('relu') (F3)\n",
    "    xa=GlobalAveragePooling2D(keepdims=True)(inputs)\n",
    "    xa=Conv2D(shape[3],1, padding='same') (xa)\n",
    "    xaa=BatchNormalization() (xa)\n",
    "    xaa=Activation('sigmoid') (xaa)\n",
    "    xm=Multiply()([F33,xaa])\n",
    "    xam=Add()([inputs,xm])\n",
    "    return xam\n",
    "\n",
    "def convformer(input_tensor, filters, padding=\"same\"):\n",
    "    # Ensure the input tensor has the expected number of filters for consistency\n",
    "    input_tensor = layers.Conv2D(filters, (1, 1), padding=padding)(input_tensor)\n",
    "\n",
    "    x = tf.keras.layers.LayerNormalization()(input_tensor)\n",
    "    x = tf.keras.layers.Conv2D(filters, kernel_size=(3,3), padding=padding)(x)\n",
    "    x = focal_modulation_context_aggregation_block(x, filters)\n",
    "\n",
    "    # Since focal_modulation_context_aggregation_block concatenates the conv1 and focal_modulation,\n",
    "    # resulting in doubling the number of filters, we need to adjust it back to the original filter size\n",
    "    # for the residual connection to work\n",
    "    x = tf.keras.layers.Conv2D(filters, (1, 1), padding=padding)(x)  # Adjust the number of filters back\n",
    "\n",
    "    out = tf.keras.layers.Add()([x, input_tensor])\n",
    "\n",
    "    x1 = tf.keras.layers.Dense(filters, activation = \"gelu\")(out)\n",
    "    x1 = tf.keras.layers.Dense(filters)(x1)\n",
    "    out_tensor = tf.keras.layers.Add()([out, x1])\n",
    "    return out_tensor\n"
   ]
  },
