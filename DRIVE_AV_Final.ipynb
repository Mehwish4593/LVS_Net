   "source": [
    "import numpy as np\n",
    "from sklearn.metrics import precision_recall_curve, confusion_matrix\n",
    "\n",
    "def evaluate_metrics_multiclass(y_test, predictions, num_classes=3):\n",
    "    n = predictions.shape[0]  # Number of samples\n",
    "    # Initialize metrics arrays\n",
    "    all_dice = np.zeros((n, num_classes))\n",
    "    all_jaccard = np.zeros((n, num_classes))\n",
    "    all_sensitivity = np.zeros((n, num_classes))\n",
    "    all_specificity = np.zeros((n, num_classes))\n",
    "    all_accuracy = np.zeros((n, num_classes))\n",
    "    all_optimal_thresholds = np.zeros((n, num_classes))\n",
    "\n",
    "    for i in range(n):\n",
    "        gt = y_test[i]\n",
    "\n",
    "        for class_id in range(num_classes):\n",
    "            gt_binary = (gt == class_id).astype(int)\n",
    "            pred_probs = predictions[i, :, :, class_id]\n",
    "\n",
    "            # Flatten arrays for metric computation\n",
    "            gt_flt = gt_binary.flatten()\n",
    "            pred_flt = pred_probs.flatten()\n",
    "\n",
    "            # Calculate precision-recall curve and F1 scores\n",
    "            precisions, recalls, thresholds = precision_recall_curve(gt_flt, pred_flt)\n",
    "            f1_scores = 2 * precisions * recalls / (precisions + recalls + 1e-6)\n",
    "            max_index = np.argmax(f1_scores)\n",
    "            optimal_threshold = thresholds[max_index] if thresholds.size > 0 else 0.5\n",
    "            pred_binary = (pred_flt >= optimal_threshold).astype(int)\n",
    "\n",
    "            # Calculate confusion matrix and derive metrics\n",
    "            if np.unique(pred_binary).size > 1:\n",
    "                tn, fp, fn, tp = confusion_matrix(gt_flt, pred_binary).ravel()\n",
    "                dice = 2 * tp / (2 * tp + fp + fn + 1e-6)\n",
    "                iou = tp / (tp + fp + fn + 1e-6)\n",
    "                sensitivity = tp / (tp + fn + 1e-6)\n",
    "                specificity = tn / (tn + fp + 1e-6)\n",
    "                accuracy = (tp + tn) / (tp + tn + fp + fn + 1e-6)\n",
    "            else:\n",
    "                dice, iou, sensitivity, specificity, accuracy = 0, 0, 0, 0, np.mean(gt_flt)\n",
    "\n",
    "            all_dice[i, class_id] = dice\n",
    "            all_jaccard[i, class_id] = iou\n",
    "            all_sensitivity[i, class_id] = sensitivity\n",
    "            all_specificity[i, class_id] = specificity\n",
    "            all_accuracy[i, class_id] = accuracy\n",
    "            all_optimal_thresholds[i, class_id] = optimal_threshold\n",
    "\n",
    "    # Calculate mean metrics across all classes\n",
    "    mean_dice = np.nanmean(all_dice, axis=1)\n",
    "    mean_jaccard = np.nanmean(all_jaccard, axis=1)\n",
    "    mean_sensitivity = np.nanmean(all_sensitivity, axis=1)\n",
    "    mean_accuracy = np.nanmean(all_accuracy, axis=1)\n",
    "    mean_specificity = np.nanmean(all_specificity, axis=1)\n",
    "\n",
    "    print('Mean Dice: {:.4f}, Mean Jaccard: {:.4f}, Mean Sensitivity: {:.4f}, Mean Accuracy: {:.4f}, Mean Specificity: {:.4f}, Optimal F1 Thresholds (per class): {}'.format(\n",
    "          np.nanmean(mean_dice), np.nanmean(mean_jaccard), np.nanmean(mean_sensitivity), np.nanmean(mean_accuracy), np.nanmean(mean_specificity),\n",
    "          np.mean(all_optimal_thresholds, axis=0)\n",
    "    ))\n",
    "\n",
    "    return mean_dice, mean_jaccard, mean_sensitivity, mean_specificity, all_optimal_thresholds\n",
    "\n",
    "# Usage Example:\n",
    "# Assuming y_test is your ground truth and predictions is your model output with shape (n, height, width, num_classes)\n",
    "# evaluate_metrics_multiclass(y_test, predictions, num_classes=3)\n"
   ]
